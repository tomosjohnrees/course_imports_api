<% content_for(:description, "Discover and share public course repositories on GitHub. A community-driven registry for course content.") %>

<div class="w-full max-w-2xl mx-auto text-center">
  <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Course Imports</h1>
  <p class="text-base sm:text-lg text-gray-600 mb-8">A community registry for public course repositories on GitHub.</p>

  <% unless user_signed_in? %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 sm:p-8">
      <p class="text-gray-700 mb-6">Sign in with your GitHub account to submit and manage courses.</p>
      <%= button_to "Sign in with GitHub", "/auth/github", method: :post, data: { turbo: false }, class: "inline-flex items-center px-6 py-3 bg-gray-900 text-white font-medium rounded-lg hover:bg-gray-700 transition-colors" %>
    </div>
  <% end %>
</div>
