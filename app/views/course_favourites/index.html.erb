<% content_for(:title, "My Favourites") %>

<div class="w-full max-w-4xl mx-auto">
  <div class="mb-8">
    <h1 class="font-heading text-3xl text-walnut tracking-wide">My Favourites</h1>
  </div>

  <% if @courses.any? %>
    <div class="space-y-4">
      <% @courses.each do |course| %>
        <%= render "courses/course_card", course: course, favourited: true %>
      <% end %>
    </div>

    <div class="mt-8">
      <%== @pagy.series_nav if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border-2 border-parchment p-12 text-center">
      <p class="text-walnut/70 mb-2">You haven't favourited any courses yet.</p>
      <p class="text-sm text-walnut/70"><%= link_to "Browse courses", courses_path, class: "text-rose font-medium hover:text-rose-dark" %> to find ones you like.</p>
    </div>
  <% end %>
</div>
