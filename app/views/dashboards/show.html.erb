<% content_for(:title, "My Courses") %>

<div class="w-full max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="font-heading text-3xl text-walnut tracking-wide">My Courses</h1>
    <%= link_to "Submit Course", new_course_path, class: "px-5 py-2 bg-rose text-white text-sm font-medium rounded-lg hover:bg-rose-dark tracking-wide transition-colors" %>
  </div>

  <% if @courses.any? %>
    <div class="space-y-3">
      <% @courses.each do |course| %>
        <div class="bg-white rounded-lg border-2 border-parchment p-4 hover:border-rose/40 transition-colors">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div class="min-w-0 flex-1">
              <%= link_to course.title, course, class: "text-base font-medium text-walnut hover:text-rose-dark truncate block transition-colors" %>
              <p class="text-sm text-walnut/50 truncate"><%= course.github_owner %>/<%= course.github_repo %></p>
            </div>

            <div class="flex items-center gap-3 shrink-0">
              <%= status_badge(course) %>

              <%= button_to "Remove", course, method: :delete, class: "text-sm text-terracotta hover:text-terracotta/70 font-medium tracking-wide transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to remove this course?" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-6">
      <%== @pagy.series_nav if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border-2 border-parchment p-8 text-center">
      <p class="text-walnut/70 mb-4">You haven't submitted any courses yet.</p>
      <%= link_to "Submit your first course", new_course_path, class: "text-rose font-medium hover:text-rose-dark transition-colors" %>
    </div>
  <% end %>
</div>
