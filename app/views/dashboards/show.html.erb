<% content_for(:title, "My Courses") %>

<div class="w-full max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="font-heading text-3xl text-walnut tracking-wide">My Courses</h1>
    <%= link_to "Submit Course", new_course_path, class: "px-5 py-2 bg-rose text-white text-sm font-medium rounded-lg hover:bg-rose-dark tracking-wide transition-colors" %>
  </div>

  <% if @courses.any? %>
    <div class="space-y-3">
      <% @courses.each do |course| %>
        <%= turbo_stream_from "course_#{course.id}" %>
        <%= render "courses/dashboard_entry", course: course %>
      <% end %>
    </div>

    <div class="mt-6">
      <%== @pagy.series_nav if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border-2 border-parchment p-8 text-center">
      <p class="text-walnut/70 mb-4">You haven't submitted any courses yet.</p>
      <%= link_to "Submit your first course", new_course_path, class: "text-rose font-medium hover:text-rose-dark transition-colors" %>
    </div>
  <% end %>
</div>
