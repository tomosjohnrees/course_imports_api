<div data-cookie-consent-target="banner" class="hidden fixed bottom-0 inset-x-0 z-50">
  <div class="max-w-3xl mx-auto px-5 pb-5">
    <div class="bg-parchment border border-walnut/20 rounded-lg shadow-lg p-5">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <p class="text-sm text-walnut flex-1">
          This site uses cookies solely to keep you signed in. No tracking or advertising cookies are used.
          See our <%= link_to "Privacy Policy", privacy_path, class: "text-rose hover:text-rose-dark underline" %> for details.
        </p>
        <button data-action="cookie-consent#dismiss"
                class="px-4 py-2 text-sm bg-sage text-cream rounded-md hover:bg-sage/90 transition-colors cursor-pointer shrink-0">
          Got it
        </button>
      </div>
    </div>
  </div>
</div>
