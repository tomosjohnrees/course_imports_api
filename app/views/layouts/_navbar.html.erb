<nav class="fixed top-0 inset-x-0 bg-cream border-b-2 border-rose z-50">
  <div class="container mx-auto px-5 h-16 flex items-center justify-between">
    <%= link_to "Course Imports", root_path, class: "font-heading text-xl tracking-wide text-walnut hover:text-rose-dark transition-colors" %>

    <% if user_signed_in? %>
      <div class="flex items-center gap-6">
        <%= link_to "My Courses", dashboard_path, class: "text-sm text-walnut/70 hover:text-walnut font-medium tracking-wide uppercase transition-colors" %>
        <div class="relative" data-controller="dropdown" data-action="click@window->dropdown#clickOutside">
        <button data-action="dropdown#toggle" class="flex items-center focus:outline-none cursor-pointer">
          <%= image_tag current_user.avatar_url, alt: current_user.github_username, class: "w-9 h-9 rounded-full border-2 border-parchment hover:border-rose transition-colors", size: "36x36", loading: "lazy" %>
        </button>

        <div class="hidden absolute right-0 mt-2 w-48 bg-cream border-2 border-rose/30 rounded-lg shadow-lg py-1" data-dropdown-target="menu">
          <div class="px-4 py-2 border-b border-rose/20">
            <span class="text-sm font-medium text-walnut"><%= current_user.github_username %></span>
          </div>
          <%= button_to "Sign out", sign_out_path, method: :delete, class: "w-full text-left px-4 py-2 text-sm text-walnut/50 hover:text-rose-dark hover:bg-parchment/50 tracking-wide uppercase transition-colors cursor-pointer" %>
        </div>
        </div>
      </div>
    <% else %>
      <%= button_to "Sign in with GitHub", "/auth/github", method: :post, data: { turbo: false }, class: "text-sm px-5 py-2 bg-rose text-white rounded-lg hover:bg-rose-dark tracking-wide transition-colors" %>
    <% end %>
  </div>
</nav>
