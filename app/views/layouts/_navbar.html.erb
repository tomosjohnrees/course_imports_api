<nav class="fixed top-0 inset-x-0 bg-white border-b border-gray-200 z-50" data-controller="nav" data-action="click@window->nav#clickOutside">
  <div class="container mx-auto px-5 h-16 flex items-center justify-between">
    <%= link_to "Course Imports", root_path, class: "text-lg font-semibold text-gray-900 hover:text-gray-700" %>

    <div class="hidden md:flex items-center gap-4">
      <%= link_to "Browse", courses_path, class: "text-sm text-gray-600 hover:text-gray-900 font-medium transition-colors" %>
      <% if user_signed_in? %>
        <%= link_to "My Courses", dashboard_courses_path, class: "text-sm text-gray-600 hover:text-gray-900 font-medium transition-colors" %>
        <%= link_to "Submit Course", new_course_path, class: "text-sm text-gray-600 hover:text-gray-900 font-medium transition-colors" %>
        <div class="flex items-center gap-3">
          <%= image_tag current_user.avatar_url, alt: current_user.github_username, class: "w-8 h-8 rounded-full", size: "32x32" %>
          <span class="text-sm font-medium text-gray-700"><%= current_user.github_username %></span>
        </div>
        <%= button_to "Sign out", sign_out_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" %>
      <% else %>
        <%= button_to "Sign in with GitHub", "/auth/github", method: :post, data: { turbo: false }, class: "text-sm px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors" %>
      <% end %>
    </div>

    <button class="md:hidden p-2 text-gray-600 hover:text-gray-900" data-action="nav#toggle" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div class="hidden md:hidden border-t border-gray-200 bg-white px-5 pb-4 pt-2 space-y-2" data-nav-target="menu">
    <%= link_to "Browse", courses_path, class: "block text-sm text-gray-600 hover:text-gray-900 font-medium py-2", data: { action: "nav#close" } %>
    <% if user_signed_in? %>
      <%= link_to "My Courses", dashboard_courses_path, class: "block text-sm text-gray-600 hover:text-gray-900 font-medium py-2", data: { action: "nav#close" } %>
      <%= link_to "Submit Course", new_course_path, class: "block text-sm text-gray-600 hover:text-gray-900 font-medium py-2", data: { action: "nav#close" } %>
      <div class="flex items-center gap-3 py-2">
        <%= image_tag current_user.avatar_url, alt: current_user.github_username, class: "w-8 h-8 rounded-full", size: "32x32" %>
        <span class="text-sm font-medium text-gray-700"><%= current_user.github_username %></span>
      </div>
      <%= button_to "Sign out", sign_out_path, method: :delete, class: "block text-sm text-gray-500 hover:text-gray-700 py-2" %>
    <% else %>
      <%= button_to "Sign in with GitHub", "/auth/github", method: :post, data: { turbo: false }, class: "block text-sm px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors text-center" %>
    <% end %>
  </div>
</nav>
