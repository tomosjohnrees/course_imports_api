<% content_for(:title, "Submit a Course") %>

<div class="w-full max-w-lg mx-auto">
  <h1 class="font-heading text-3xl text-walnut tracking-wide mb-2">Submit a Course</h1>
  <p class="text-walnut/60 mb-8">Add a public GitHub repository to the course registry. Your repo will be validated automatically.</p>

  <%= form_with model: @course, class: "space-y-6" do |f| %>
    <% if @course.errors.any? %>
      <div class="bg-rose-light border-2 border-rose/30 rounded-lg px-4 py-3 text-sm text-rose-dark">
        <% @course.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :github_repo_url, "GitHub Repository URL", class: "block text-sm font-medium text-walnut/80 mb-1 uppercase tracking-wider" %>
      <%= f.url_field :github_repo_url, placeholder: "https://github.com/owner/repo", class: "w-full px-3 py-2.5 border-2 border-parchment bg-white rounded-lg focus:outline-none focus:border-rose focus:ring-1 focus:ring-rose transition-colors" %>
      <p class="mt-1.5 text-sm text-walnut/50">Enter the full URL of a public GitHub repository.</p>
    </div>

    <div class="bg-parchment/50 border-2 border-mustard/30 rounded-lg px-4 py-3 text-sm text-walnut/70 space-y-1">
      <p class="font-medium text-walnut/80 uppercase tracking-wider text-xs">Your repository must include:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <li>A <code class="text-xs bg-mustard-light px-1.5 py-0.5 rounded">course.json</code> with title, description, and topic order</li>
        <li>A <code class="text-xs bg-mustard-light px-1.5 py-0.5 rounded">topics/</code> directory with a <code class="text-xs bg-mustard-light px-1.5 py-0.5 rounded">content.json</code> in each topic folder</li>
        <li>The repo must be public and not archived</li>
      </ul>
    </div>

    <%= f.submit "Submit Course", class: "w-full px-4 py-2.5 bg-rose text-white font-medium rounded-lg hover:bg-rose-dark tracking-wide transition-colors cursor-pointer" %>
  <% end %>
</div>
