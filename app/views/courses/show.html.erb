<% content_for(:title, @course.title) %>
<% content_for(:description, truncate(@course.description.presence || "A course on GitHub submitted to the Course Imports registry.", length: 160)) %>

<%= turbo_stream_from "course_#{@course.id}" %>

<div class="w-full max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to "&larr; Back to courses".html_safe, courses_path, class: "text-sm text-rose hover:text-rose-dark transition-colors" %>
  </div>

  <div class="mb-6">
    <h1 class="font-heading text-3xl text-walnut tracking-wide mb-2"><%= @course.title %></h1>
    <a href="<%= @course.github_repo_url %>" target="_blank" rel="noopener noreferrer" class="text-sm text-walnut/50 hover:text-rose transition-colors">
      <%= @course.github_owner %>/<%= @course.github_repo %>
    </a>
  </div>

  <div class="bg-white rounded-lg border-2 border-parchment p-6 space-y-5">
    <%= render "courses/status", course: @course %>

    <% if @course.description.present? %>
      <div>
        <h2 class="text-xs font-medium text-walnut/50 mb-1 uppercase tracking-wider">Description</h2>
        <p class="text-walnut/80"><%= @course.description %></p>
      </div>
    <% end %>

    <% if @course.author_name.present? %>
      <div>
        <h2 class="text-xs font-medium text-walnut/50 mb-1 uppercase tracking-wider">Author</h2>
        <p class="text-walnut/80"><%= @course.author_name %></p>
      </div>
    <% end %>

    <% if @course.tags.present? %>
      <div>
        <h2 class="text-xs font-medium text-walnut/50 mb-1 uppercase tracking-wider">Tags</h2>
        <div class="flex flex-wrap gap-2">
          <% @course.tags.each do |tag| %>
            <%= link_to tag, courses_path(tag: tag), class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-sage-light text-sage border border-sage/20 hover:bg-sage hover:text-white transition-colors" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex flex-wrap gap-6">
      <% unless @course.topic_count.nil? %>
        <div>
          <h2 class="text-xs font-medium text-walnut/50 mb-1 uppercase tracking-wider">Topics</h2>
          <p class="text-walnut/80"><%= @course.topic_count %> <%= "topic".pluralize(@course.topic_count) %></p>
        </div>
      <% end %>

      <div>
        <h2 class="text-xs font-medium text-walnut/50 mb-1 uppercase tracking-wider">Loads</h2>
        <p class="text-walnut/80"><%= @course.load_count %> <%= "load".pluralize(@course.load_count) %></p>
      </div>

      <% if @course.version.present? %>
        <div>
          <h2 class="text-xs font-medium text-walnut/50 mb-1 uppercase tracking-wider">Version</h2>
          <p class="text-walnut/80"><%= @course.version %></p>
        </div>
      <% end %>
    </div>

    <div class="pt-4 border-t-2 border-parchment flex flex-wrap gap-3">
      <a href="<%= @course.github_repo_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-5 py-2 bg-rose text-white text-sm font-medium rounded-lg hover:bg-rose-dark tracking-wide transition-colors">
        View on GitHub
      </a>

      <% if @course.approved? %>
        <a href="<%= @course.deep_link_url %>" class="inline-flex items-center px-5 py-2 bg-white text-walnut text-sm font-medium rounded-lg border-2 border-walnut hover:bg-parchment/50 tracking-wide transition-colors" data-controller="track-load" data-track-load-url-value="<%= track_load_course_path(@course.github_owner, @course.github_repo) %>" data-action="click->track-load#track">
          Open in app
        </a>
      <% end %>
    </div>

    <% if user_signed_in? && @course.user == current_user %>
      <div class="pt-4 border-t-2 border-parchment flex gap-3">
        <%= button_to "Remove Course", @course, method: :delete, class: "px-5 py-2 bg-terracotta text-white text-sm font-medium rounded-lg hover:bg-terracotta/80 tracking-wide transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to remove this course?" } %>
        <% if @course.failed? %>
          <%= button_to "Resubmit for Validation", resubmit_course_path(@course.github_owner, @course.github_repo), method: :post, class: "px-5 py-2 bg-rose text-white text-sm font-medium rounded-lg hover:bg-rose-dark tracking-wide transition-colors cursor-pointer" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
