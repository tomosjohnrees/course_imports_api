<% content_for(:title, @course.title) %>

<%= turbo_stream_from "course_#{@course.id}" %>

<div class="w-full max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to "&larr; Back to courses".html_safe, courses_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @course.title %></h1>
    <a href="<%= @course.github_repo_url %>" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 hover:text-gray-700">
      <%= @course.github_owner %>/<%= @course.github_repo %>
    </a>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 space-y-5">
    <%= render "courses/status", course: @course %>

    <% if @course.description.present? %>
      <div>
        <h2 class="text-sm font-medium text-gray-500 mb-1">Description</h2>
        <p class="text-gray-700"><%= @course.description %></p>
      </div>
    <% end %>

    <% if @course.author_name.present? %>
      <div>
        <h2 class="text-sm font-medium text-gray-500 mb-1">Author</h2>
        <p class="text-gray-700"><%= @course.author_name %></p>
      </div>
    <% end %>

    <% if @course.tags.present? %>
      <div>
        <h2 class="text-sm font-medium text-gray-500 mb-1">Tags</h2>
        <div class="flex flex-wrap gap-2">
          <% @course.tags.each do |tag| %>
            <%= link_to tag, courses_path(tag: tag), class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex flex-wrap gap-6">
      <% unless @course.topic_count.nil? %>
        <div>
          <h2 class="text-sm font-medium text-gray-500 mb-1">Topics</h2>
          <p class="text-gray-700"><%= @course.topic_count %> <%= "topic".pluralize(@course.topic_count) %></p>
        </div>
      <% end %>

      <div>
        <h2 class="text-sm font-medium text-gray-500 mb-1">Loads</h2>
        <p class="text-gray-700"><%= @course.load_count %> <%= "load".pluralize(@course.load_count) %></p>
      </div>

      <% if @course.version.present? %>
        <div>
          <h2 class="text-sm font-medium text-gray-500 mb-1">Version</h2>
          <p class="text-gray-700"><%= @course.version %></p>
        </div>
      <% end %>
    </div>

    <div class="pt-4 border-t border-gray-200 flex flex-wrap gap-3">
      <a href="<%= @course.github_repo_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors">
        View on GitHub
      </a>

      <% if @course.approved? %>
        <a href="<%= @course.deep_link_url %>" class="inline-flex items-center px-4 py-2 bg-white text-gray-900 text-sm font-medium rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors">
          Open in app
        </a>
      <% end %>
    </div>

    <% if user_signed_in? && @course.user == current_user && (!@course.removed? || @course.failed?) %>
      <div class="pt-4 border-t border-gray-200 flex gap-3">
        <% unless @course.removed? %>
          <%= button_to "Remove Course", @course, method: :delete, class: "px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-500 transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to remove this course?" } %>
        <% end %>
        <% if @course.failed? %>
          <%= button_to "Resubmit for Validation", resubmit_course_path(@course), method: :post, class: "px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors cursor-pointer" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
