<div>
  <h2 class="text-xs font-medium text-walnut/50 mb-1 uppercase tracking-wider">Status</h2>
  <div class="flex items-center gap-2">
    <%= status_badge(course) %>
  </div>
  <% if course.failed? && course.validation_error.present? %>
    <p class="mt-2 text-sm text-terracotta"><%= course.validation_error %></p>
  <% end %>
</div>
