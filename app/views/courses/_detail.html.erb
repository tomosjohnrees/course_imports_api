<div id="course_<%= course.id %>" class="space-y-5">
  <% if course.approved? %>
    <div>
      <%= link_to "Open in app", course.deep_link_url, class: "inline-flex items-center px-5 py-2.5 bg-rose text-white text-sm font-medium rounded-lg hover:bg-rose-dark tracking-wide transition-colors", data: { controller: "track-load", track_load_url_value: track_load_course_path(course.github_owner, course.github_repo), action: "click->track-load#track" } %>
    </div>
  <% end %>

  <%= render "courses/status", course: course %>

  <% if course.description.present? %>
    <div>
      <h2 class="text-xs font-medium text-walnut/70 mb-1 uppercase tracking-wider">Description</h2>
      <p class="text-walnut/80"><%= course.description %></p>
    </div>
  <% end %>

  <% if course.author_name.present? %>
    <div>
      <h2 class="text-xs font-medium text-walnut/70 mb-1 uppercase tracking-wider">Author</h2>
      <p class="text-walnut/80"><%= course.author_name %></p>
    </div>
  <% end %>

  <% if course.tags.present? %>
    <div>
      <h2 class="text-xs font-medium text-walnut/70 mb-1 uppercase tracking-wider">Tags</h2>
      <div class="flex flex-wrap gap-2">
        <% course.tags.each do |tag| %>
          <%= link_to tag, courses_path(tag: tag), class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-sage-light text-sage border border-sage/20 hover:bg-sage hover:text-white transition-colors" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="flex flex-wrap gap-6">
    <% unless course.topic_count.nil? %>
      <div>
        <h2 class="text-xs font-medium text-walnut/70 mb-1 uppercase tracking-wider">Topics</h2>
        <p class="text-walnut/80"><%= course.topic_count %> <%= "topic".pluralize(course.topic_count) %></p>
      </div>
    <% end %>

    <div>
      <h2 class="text-xs font-medium text-walnut/70 mb-1 uppercase tracking-wider">Loads</h2>
      <p class="text-walnut/80"><%= course.load_count %> <%= "load".pluralize(course.load_count) %></p>
    </div>

    <% if course.version.present? %>
      <div>
        <h2 class="text-xs font-medium text-walnut/70 mb-1 uppercase tracking-wider">Version</h2>
        <p class="text-walnut/80"><%= course.version %></p>
      </div>
    <% end %>
  </div>

  <div class="pt-4 border-t-2 border-parchment">
    <%= link_to "View on GitHub →", course.github_repo_url, target: "_blank", rel: "noopener noreferrer", class: "text-sm text-walnut/70 hover:text-rose transition-colors" %>
  </div>
</div>
